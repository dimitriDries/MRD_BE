---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { site } from "../../data/site";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// PRE-LAUNCH: noindex keeps this page out of search engines while empty.
// When the blog goes live, set noindex={false} (see example-post.md checklist).
---

<Base
  title={`Blog | ${site.name}`}
  description="Notes on digital analytics, GA4, BigQuery and measurement, by MonsieurData."
  noindex={true}
  pageName="blog index"
  pageType="blog"
>
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Blog</p>
        <h1 class="blog-title">Notes on data & measurement.</h1>
      </div>

      {posts.length === 0 ? (
        <p class="blog-empty">First posts are brewing. Check back soon. ☕</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li class="post-card">
              <a href={`/blog/${post.id.replace(/\.md$/, "")}`}>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("en-GB", {
                    day: "numeric",
                    month: "short",
                    year: "numeric",
                  })}
                </time>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</Base>

<style>
  .blog-title {
    font-size: clamp(2rem, 4.5vw, 3rem);
  }

  .blog-empty {
    color: var(--muted);
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
    max-width: 44rem;
  }

  .post-card a {
    display: block;
    text-decoration: none;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.75rem 2rem;
    transition: transform 0.25s var(--ease-out), border-color 0.25s;
  }

  .post-card a:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--red) 40%, var(--line));
  }

  .post-card time {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
  }

  .post-card h2 {
    font-size: 1.3rem;
    margin-top: 0.4rem;
  }

  .post-card p {
    color: var(--muted);
    margin-top: 0.5rem;
    font-size: 0.97rem;
  }
</style>
