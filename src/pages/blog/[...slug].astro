---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import { site } from "../../data/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// PRE-LAUNCH: noindex until the blog officially launches.
---

<Base title={`${post.data.title} | ${site.name}`} description={post.data.description} noindex={true} pageName={post.data.title} pageType="blog post">
  <article class="section">
    <div class="container post">
      <p class="eyebrow">Blog</p>
      <h1>{post.data.title}</h1>
      <p class="post__meta">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString("en-GB", {
            day: "numeric",
            month: "long",
            year: "numeric",
          })}
        </time>
        {post.data.tags.length > 0 && <span> · {post.data.tags.join(", ")}</span>}
      </p>
      <div class="post__body">
        <Content />
      </div>
      <a class="link" href="/blog">← All posts</a>
    </div>
  </article>
</Base>

<style>
  .post {
    max-width: 44rem;
  }

  .post h1 {
    font-size: clamp(2rem, 4.5vw, 3rem);
  }

  .post__meta {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    margin-top: 1rem;
  }

  .post__body {
    margin-block: 2.5rem 3rem;
  }

  .post__body :global(h2) {
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
  }

  .post__body :global(p),
  .post__body :global(li) {
    margin-bottom: 1rem;
  }

  .post__body :global(a) {
    color: var(--red);
  }

  .post__body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--red-tint);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }
</style>
