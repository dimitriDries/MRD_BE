---
import { hero } from "../data/site";
---

<section class="hero section--dark" aria-label="Introduction">
  <div class="hero__slashes" aria-hidden="true">
    <span class="hero__slash hero__slash--1" data-parallax="0.18"></span>
    <span class="hero__slash hero__slash--2" data-parallax="0.10"></span>
    <span class="hero__slash hero__slash--3" data-parallax="0.26"></span>
  </div>

  <div class="container hero__inner">
    <p class="eyebrow" data-reveal>{hero.eyebrow}</p>
    <h1 data-reveal style="--reveal-delay: 0.08s">
      {hero.headline[0]}<br />
      <span class="hero__accent">{hero.headline[1]}</span>
    </h1>
    <p class="hero__sub" data-reveal style="--reveal-delay: 0.16s">{hero.sub}</p>
    <div class="hero__actions" data-reveal style="--reveal-delay: 0.24s">
      <a href={hero.primaryCta.href} class="btn btn--primary">{hero.primaryCta.label}</a>
      <a href={hero.secondaryCta.href} class="btn btn--ghost">{hero.secondaryCta.label}</a>
    </div>

    <dl class="hero__stats" data-reveal style="--reveal-delay: 0.32s">
      {hero.stats.map((stat) => (
        <div class="hero__stat">
          <dt class="visually-hidden">{stat.label}</dt>
          <dd>
            <span class="hero__stat-value" data-countup data-value={stat.value} data-suffix={stat.suffix}>
              0{stat.suffix}
            </span>
            <span class="hero__stat-label">{stat.label}</span>
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(6rem, 14vh, 9.5rem) clamp(4rem, 9vh, 6rem);
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: 50rem;
  }

  .hero__accent {
    color: var(--red);
    /* a touch brighter on dark so it doesn't sink into the ink */
    filter: brightness(1.35);
  }

  .hero__sub {
    font-size: clamp(1.1rem, 1.8vw, 1.3rem);
    color: var(--muted-inv);
    max-width: 36rem;
    margin-top: 1.75rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(2rem, 5vw, 4.5rem);
    margin: 4.5rem 0 0;
    padding-top: 2.25rem;
    border-top: 1px solid color-mix(in srgb, var(--paper-inv) 15%, transparent);
  }

  .hero__stat dd {
    margin: 0;
    display: grid;
    gap: 0.2rem;
  }

  .hero__stat-value {
    font-family: var(--font-mono);
    font-size: clamp(1.75rem, 3vw, 2.4rem);
    font-weight: 500;
    color: var(--paper-inv);
  }

  .hero__stat-label {
    font-size: 0.875rem;
    color: var(--muted-inv);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
  }

  /* Decorative slashes - same angle as the logo */
  .hero__slashes {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__slash {
    position: absolute;
    width: clamp(60px, 8vw, 110px);
    height: 160%;
    top: -30%;
    background: var(--red);
    transform: skewX(calc(-1 * var(--slash-angle)));
    will-change: transform;
  }

  .hero__slash--1 {
    right: 6%;
    opacity: 0.92;
  }

  .hero__slash--2 {
    right: 18%;
    width: clamp(14px, 2vw, 26px);
    opacity: 0.45;
  }

  .hero__slash--3 {
    right: -4%;
    width: clamp(18px, 2.5vw, 34px);
    opacity: 0.25;
  }

  @media (max-width: 900px) {
    .hero__slash--1 { right: -8%; opacity: 0.5; }
    .hero__slash--2 { right: 4%; opacity: 0.3; }
    .hero__slash--3 { display: none; }
  }
</style>

<script>
  // Parallax drift for the hero slashes; cheap (transform-only, rAF-throttled).
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const layers = document.querySelectorAll<HTMLElement>("[data-parallax]");

  if (!reduced && layers.length) {
    let ticking = false;
    const update = () => {
      const y = window.scrollY;
      layers.forEach((el) => {
        const speed = Number(el.dataset.parallax ?? 0.15);
        el.style.transform = `skewX(calc(-1 * var(--slash-angle))) translateY(${y * speed}px)`;
      });
      ticking = false;
    };
    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      },
      { passive: true }
    );
  }
</script>
