---
import { nav, site } from "../data/site";
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__brand" aria-label={`${site.name} home`}>
      <img src="/images/mrd_thumbnail.png" alt="" width="40" height="40" loading="eager" />
      <span>Monsieur<strong>Data</strong></span>
    </a>

    <nav class="header__nav" aria-label="Main navigation">
      <ul>
        {nav.links.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <a href={nav.cta.href} class="btn btn--primary header__cta">{nav.cta.label}</a>

    <button class="header__toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span>
    </button>
  </div>

  <div class="header__mobile" id="mobile-menu" hidden>
    <ul>
      {nav.links.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
      <li><a href={nav.cta.href} class="btn btn--primary">{nav.cta.label}</a></li>
    </ul>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding-block: 0.8rem;
  }

  .header__brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 1.2rem;
    margin-right: auto;
  }

  .header__brand strong {
    color: var(--red);
  }

  .header__nav ul {
    display: flex;
    gap: 1.9rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__nav a {
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--ink);
    opacity: 0.85;
    transition: opacity 0.2s, color 0.2s;
  }

  .header__nav a:hover {
    opacity: 1;
    color: var(--red);
  }

  .header__cta {
    padding: 0.6rem 1.25rem;
    font-size: 0.9rem;
  }

  .header__toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: 0;
    padding: 0.5rem;
    cursor: pointer;
  }

  .header__toggle span {
    width: 24px;
    height: 2px;
    background: var(--ink);
    transition: transform 0.25s var(--ease-out);
  }

  .header__toggle[aria-expanded="true"] span:first-child {
    transform: translateY(4px) rotate(-45deg);
  }

  .header__toggle[aria-expanded="true"] span:last-child {
    transform: translateY(-4px) rotate(45deg);
  }

  .header__mobile {
    border-top: 1px solid var(--line);
    padding: 1.25rem 1.5rem 1.75rem;
  }

  .header__mobile ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .header__mobile a:not(.btn) {
    text-decoration: none;
    font-weight: 600;
    font-size: 1.05rem;
  }

  @media (max-width: 820px) {
    .header__nav,
    .header__cta {
      display: none;
    }

    .header__toggle {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".header__toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!open));
    toggle.setAttribute("aria-label", open ? "Open menu" : "Close menu");
    if (menu) menu.hidden = open;
  });
  // Close the mobile menu after navigating to an anchor.
  menu?.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).closest("a")) {
      menu.hidden = true;
      toggle?.setAttribute("aria-expanded", "false");
    }
  });
</script>
