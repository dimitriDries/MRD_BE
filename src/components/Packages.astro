---
import { packages, site } from "../data/site";
---

<section class="section" id="services" aria-labelledby="packages-title">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow" data-reveal>{packages.eyebrow}</p>
      <h2 id="packages-title" data-reveal style="--reveal-delay: 0.06s">{packages.title}</h2>
      <p class="lede" data-reveal style="--reveal-delay: 0.12s">{packages.lede}</p>
    </div>

    <div class="tiers">
      {packages.tiers.map((tier, i) => (
        <article
          class:list={["tier", { "tier--featured": tier.featured }]}
          data-reveal
          style={`--reveal-delay: ${i * 0.1}s`}
        >
          {tier.featured && <p class="tier__badge">{tier.badge}</p>}
          <h3>{tier.name}</h3>
          <p class="tier__tagline">{tier.tagline}</p>
          <p class="tier__duration">{tier.duration}</p>
          <p class="tier__desc">{tier.description}</p>
          <ul class="tier__list">
            {tier.includes.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a
            href="#contact"
            class:list={["btn", tier.featured ? "btn--primary" : "btn--ghost", "tier__cta"]}
          >
            {tier.cta}
          </a>
        </article>
      ))}
    </div>

    <p class="tiers__note" data-reveal>
      {packages.note}
      <a class="link" href={`mailto:${site.email}`}>Or just send a mail.</a>
    </p>
  </div>
</section>

<style>
  .tiers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    align-items: stretch;
  }

  .tier {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 2.25rem 2rem;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }

  .tier:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 44px -24px rgba(22, 18, 15, 0.35);
  }

  .tier--featured {
    border-color: var(--red);
    border-width: 1.5px;
  }

  .tier__badge {
    position: absolute;
    top: -0.8rem;
    left: 2rem;
    background: var(--red);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.7rem;
  }

  .tier h3 {
    font-size: 1.35rem;
  }

  .tier__tagline {
    color: var(--muted);
    font-size: 0.95rem;
    margin-top: 0.25rem;
  }

  .tier__duration {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-top: 1.4rem;
  }

  .tier__desc {
    margin-top: 1.1rem;
    font-size: 0.97rem;
    color: var(--muted);
  }

  .tier__list {
    list-style: none;
    margin: 1.5rem 0 2rem;
    padding: 0;
    display: grid;
    gap: 0.65rem;
    font-size: 0.95rem;
  }

  .tier__list li {
    padding-left: 1.4rem;
    position: relative;
  }

  /* the slash as a list marker */
  .tier__list li::before {
    content: "";
    position: absolute;
    left: 0.2rem;
    top: 0.32em;
    width: 4px;
    height: 0.95em;
    background: var(--red);
    transform: skewX(calc(-1 * var(--slash-angle)));
  }

  .tier__cta {
    margin-top: auto;
    justify-content: center;
  }

  .tiers__note {
    text-align: center;
    color: var(--muted);
    margin-top: 2.75rem;
    font-size: 0.97rem;
  }
</style>
