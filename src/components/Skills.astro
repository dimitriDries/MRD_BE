---
import { skills } from "../data/site";
---

<section
  class="section section--dark"
  id="skills"
  aria-labelledby="skills-title"
  data-section="skills"
  data-content
  data-content-type="section"
  data-content-id="skills"
>
  <div class="container">
    <div class="section-head">
      <p class="eyebrow" data-reveal>{skills.eyebrow}</p>
      <h2 id="skills-title" data-reveal style="--reveal-delay: 0.06s">{skills.title}</h2>
      <p class="lede" data-reveal style="--reveal-delay: 0.12s">{skills.lede}</p>
    </div>

    <div class="skills">
      {skills.groups.map((group, i) => (
        <div
          class="skills__group"
          data-reveal
          style={`--reveal-delay: ${i * 0.1}s`}
          data-content
          data-content-type="skill group"
          data-content-name={`skill group ${i + 1}`}
        >
          <h3>{group.title}</h3>
          <ul>
            {group.items.map((item) => (
              <li class="skills__chip" data-interactive data-content-type="skill" data-content-name={item}>{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p class="skills__note" data-reveal>
      <span class="slash" aria-hidden="true"></span>
      {skills.note}
    </p>
  </div>
</section>

<style>
  .skills {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2.5rem;
  }

  .skills__note {
    margin-top: clamp(2.75rem, 5vw, 3.75rem);
    padding-top: clamp(1.75rem, 3vw, 2.25rem);
    border-top: 1px solid color-mix(in srgb, var(--paper-inv) 15%, transparent);
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    color: var(--muted-inv);
    font-size: 0.97rem;
    line-height: 1.6;
    max-width: 48rem;
  }

  .skills__note .slash {
    flex: 0 0 auto;
    width: 4px;
    height: 1.5em;
    margin-top: 0.05em;
  }

  .skills__group h3 {
    font-size: 1.05rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid color-mix(in srgb, var(--paper-inv) 15%, transparent);
  }

  .skills__group ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .skills__chip {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--paper-inv);
    background: var(--ink-soft);
    border: 1px solid color-mix(in srgb, var(--paper-inv) 12%, transparent);
    padding: 0.42rem 0.85rem;
    transition: border-color 0.25s, transform 0.25s var(--ease-out);
  }

  .skills__chip:hover {
    border-color: var(--red);
    transform: translateY(-2px);
  }
</style>
