---
import { valueProp } from "../data/site";

const iconSrc: Record<string, string> = {
  tagmanagement: "/images/tagmanagement_icon.svg",
  development: "/images/development_icon.svg",
  reporting: "/images/reporting_icon.svg",
  privacy: "/images/privacy_icon.svg",
};
---

<section class="section" id="approach" aria-labelledby="valueprop-title">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow" data-reveal>{valueProp.eyebrow}</p>
      <h2 id="valueprop-title" data-reveal style="--reveal-delay: 0.06s">{valueProp.title}</h2>
      <p class="lede" data-reveal style="--reveal-delay: 0.12s">{valueProp.lede}</p>
    </div>

    <div class="pillars">
      {valueProp.pillars.map((pillar, i) => (
        <article class="pillar" data-reveal style={`--reveal-delay: ${i * 0.08}s`}>
          <img src={iconSrc[pillar.icon]} alt="" width="44" height="44" loading="lazy" />
          <h3>{pillar.title}</h3>
          <p>{pillar.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .pillar {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out),
      border-color 0.3s;
  }

  .pillar:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px -22px rgba(22, 18, 15, 0.35);
    border-color: color-mix(in srgb, var(--red) 35%, var(--line));
  }

  .pillar img {
    margin-bottom: 1.25rem;
  }

  .pillar h3 {
    font-size: 1.15rem;
    margin-bottom: 0.6rem;
  }

  .pillar p {
    color: var(--muted);
    font-size: 0.97rem;
  }
</style>
