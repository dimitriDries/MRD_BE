---
import Base from "./Base.astro";
import { legalUpdated } from "../data/legal";

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---

<Base title={`${title} | MonsieurData`} description={description}>
  <article class="section legal">
    <div class="container legal__inner">
      <p class="eyebrow">Legal</p>
      <h1>{title}</h1>
      <p class="legal__updated">Last updated: {legalUpdated}</p>
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</Base>

<style>
  .legal__inner { max-width: 48rem; }
  .legal h1 { font-size: clamp(2rem, 4.5vw, 2.9rem); }
  .legal__updated {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--muted);
    margin-top: 0.75rem;
  }
  .prose { margin-top: 2.5rem; }
  .prose :global(h2) {
    font-size: 1.4rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose :global(h3) {
    font-size: 1.1rem;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }
  .prose :global(p),
  .prose :global(li) {
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 0.9rem;
  }
  .prose :global(ul) { padding-left: 1.25rem; margin-bottom: 1rem; }
  .prose :global(a) { color: var(--red); text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(strong) { color: var(--ink); }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0 1.75rem;
    font-size: 0.9rem;
  }
  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--line);
    padding: 0.6rem 0.75rem;
    text-align: left;
    vertical-align: top;
  }
  .prose :global(th) {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--surface);
    color: var(--ink);
  }
  .prose :global(.legal-note) {
    background: var(--red-tint);
    border-left: 3px solid var(--red);
    padding: 1rem 1.25rem;
    border-radius: var(--radius);
    margin: 1.5rem 0;
    font-size: 0.92rem;
  }
  .prose :global(.legal-note p:last-child) { margin-bottom: 0; }
</style>
